<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="550.0" prefWidth="700.0" style="-fx-background-color: #f4f4f4; -fx-border-color: #2c3e50; -fx-border-width: 2;" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ReceberController">
   <children>
      <Label layoutX="20.0" layoutY="20.0" text="Contas a Receber (Boletos/Crediário)" textFill="#2c3e50">
         <font><Font name="System Bold" size="22.0" /></font>
      </Label>

      <HBox alignment="CENTER_LEFT" layoutX="20.0" layoutY="65.0" spacing="15.0">
         <children>
            <Button mnemonicParsing="false" onAction="#selecionarCliente" prefHeight="30.0" style="-fx-cursor: hand;" text="Localizar Cliente" />
            <Label fx:id="lblClienteNome" text="Nenhum cliente selecionado" textFill="#2980b9">
               <font><Font name="System Bold Italic" size="14.0" /></font>
            </Label>
         </children>
      </HBox>

      <TableView fx:id="tabelaPendencias" layoutX="20.0" layoutY="110.0" prefHeight="280.0" prefWidth="660.0">
        <columns>
          <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />
          <TableColumn fx:id="colParcela" prefWidth="90.0" text="Nº Parcela" />
          <TableColumn fx:id="colVencimento" prefWidth="150.0" text="Vencimento" />
          <TableColumn fx:id="colTotal" prefWidth="130.0" text="Valor Parcela" />
          <TableColumn fx:id="colStatus" prefWidth="150.0" text="Status do Boleto" />
        </columns>
      </TableView>

      <VBox layoutX="20.0" layoutY="410.0" spacing="8.0">
         <children>
            <Label text="Resumo do Recebimento:" style="-fx-font-weight: bold;">
               <font><Font size="14.0" /></font>
            </Label>
            <Label fx:id="lblTotalPagar" text="Total a Receber: R$ 0,00" textFill="#27ae60">
               <font><Font name="System Bold" size="20.0" /></font>
            </Label>
            <Label text="* Ao baixar a última parcela, o cliente retornará ao status ATIVO automaticamente." textFill="#7f8c8d">
               <font><Font size="11.0" /></font>
            </Label>
         </children>
      </VBox>

      <HBox layoutX="420.0" layoutY="490.0" spacing="15.0">
         <children>
            <Button mnemonicParsing="false" onAction="#cancelar" prefHeight="35.0" prefWidth="110.0" style="-fx-cursor: hand;" text="Cancelar" />
            <Button mnemonicParsing="false" onAction="#confirmarPagamento" prefHeight="35.0" prefWidth="145.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-cursor: hand;" text="BAIXAR PARCELA" />
         </children>
      </HBox>
   </children>
</AnchorPane>