<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="300.0" prefWidth="400.0" style="-fx-border-color: #d32f2f; -fx-border-width: 5;" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.AutorizacaoController">
   <children>
      <Label layoutX="20.0" layoutY="20.0" text="Autorização Necessária" textFill="#d32f2f">
         <font>
            <Font name="System Bold" size="20.0" />
         </font>
      </Label>
      <Label layoutX="20.0" layoutY="60.0" text="O desconto solicitado ultrapassa o limite de 5%." />
      <Label layoutX="20.0" layoutY="80.0" text="Insira as credenciais de Gerente para liberar a venda." />

      <Label layoutX="50.0" layoutY="130.0" text="Usuário do Gerente:" />
      <TextField fx:id="txtUsuarioGerente" layoutX="50.0" layoutY="150.0" prefWidth="300.0" />

      <Label layoutX="50.0" layoutY="190.0" text="Senha:" />
      <PasswordField fx:id="txtSenhaGerente" layoutX="50.0" layoutY="210.0" prefWidth="300.0" />

      <Button fx:id="btnAutorizar" layoutX="190.0" layoutY="250.0" mnemonicParsing="false" onAction="#confirmarAutorizacao" prefHeight="30.0" prefWidth="100.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="Autorizar">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Button>
      
      <Button fx:id="btnCancelar" layoutX="300.0" layoutY="250.0" mnemonicParsing="false" onAction="#cancelar" prefHeight="30.0" prefWidth="80.0" style="-fx-background-color: #F44336; -fx-text-fill: white;" text="Cancelar" />
   </children>
</AnchorPane>