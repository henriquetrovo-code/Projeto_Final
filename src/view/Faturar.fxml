<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.FaturarController">
   <children>
      <Label layoutX="30.0" layoutY="25.0" text="Pedidos Aguardando Faturamento (Caixa)" textFill="#1a237e">
         <font>
            <Font name="System Bold" size="22.0" />
         </font>
      </Label>
      
      <TableView fx:id="tabelaPendentes" layoutX="14.0" layoutY="82.0" prefHeight="400.0" prefWidth="740.0">
        <columns>
          <TableColumn fx:id="colId" prefWidth="80.0" text="Nº Pedido" />
          <TableColumn fx:id="colCliente" prefWidth="300.0" text="Nome do Cliente" />
          <TableColumn fx:id="colData" prefWidth="200.0" text="Data do Pedido" />
          <TableColumn fx:id="colTotal" prefWidth="150.0" text="Valor Total R$" />
        </columns>
      </TableView>
      
      <Button layoutX="570.0" layoutY="500.0" mnemonicParsing="false" onAction="#confirmarFaturamento" prefHeight="50.0" prefWidth="200.0" style="-fx-background-color: #2e7d32; -fx-text-fill: white;" text="CONFIRMAR E FATURAR">
         <font>
            <Font name="System Bold" size="14.0" />
         </font>
      </Button>
      
      <Label layoutX="30.0" layoutY="490.0" text="Dica: O faturamento atualiza o estoque e o saldo do cliente." textFill="#757575">
         <font>
            <Font name="System Italic" size="12.0" />
         </font>
      </Label>
      <ImageView fitHeight="81.0" fitWidth="141.0" layoutX="570.0" layoutY="3.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../../../../Downloads/Logo%20HyperTech.png" />
         </image>
      </ImageView>
   </children>
</AnchorPane>
