<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="450.0" prefWidth="550.0" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.BuscaClienteController">
   <children>
      <Label layoutX="20.0" layoutY="15.0" text="Selecionar Cliente" textFill="#2c3e50">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      
      <TextField fx:id="txtBuscaNome" layoutX="20.0" layoutY="55.0" onKeyPressed="#verificarEnter" prefHeight="35.0" prefWidth="390.0" promptText="Digite o nome do cliente e aperte Pesquisar..." style="-fx-background-color: white; -fx-border-color: #cccccc; -fx-border-radius: 3;" />
      
      <Button layoutX="420.0" layoutY="55.0" mnemonicParsing="false" onAction="#pesquisar" prefHeight="35.0" prefWidth="110.0" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-cursor: hand;" text="Pesquisar">
         <font>
            <Font name="System Bold" size="13.0" />
         </font>
      </Button>

      <TableView fx:id="tabelaClientes" layoutX="20.0" layoutY="105.0" onKeyPressed="#verificarEnter" prefHeight="280.0" prefWidth="510.0" style="-fx-border-color: #cccccc;">
        <columns>
          <TableColumn fx:id="colId" prefWidth="80.0" text="Código" />
          <TableColumn fx:id="colNome" prefWidth="428.0" text="Nome do Cliente" />
        </columns>
      </TableView>

      <Button layoutX="380.0" layoutY="400.0" mnemonicParsing="false" onAction="#confirmarSelecao" prefHeight="35.0" prefWidth="150.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold;" text="Confirmar (Enter)" />
      
      <Label layoutX="20.0" layoutY="409.0" text="Dica: Dê um duplo clique no nome para selecionar direto." textFill="#7f8c8d">
         <font>
            <Font name="System Italic" size="12.0" />
         </font>
      </Label>
   </children>
</AnchorPane>