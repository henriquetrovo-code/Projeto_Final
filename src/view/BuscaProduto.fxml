<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="450.0" prefWidth="600.0" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.BuscaProdutoController">
   <children>
      <Label layoutX="20.0" layoutY="15.0" text="Selecionar Produto" textFill="#2c3e50">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      
      <TextField fx:id="txtBuscaProduto" layoutX="20.0" layoutY="55.0" onKeyPressed="#verificarEnter" prefHeight="35.0" prefWidth="440.0" promptText="Busque por Nome, ID ou Código de Barras..." style="-fx-background-color: white; -fx-border-color: #cccccc; -fx-border-radius: 3;" />
      
      <Button layoutX="470.0" layoutY="55.0" mnemonicParsing="false" onAction="#pesquisar" prefHeight="35.0" prefWidth="110.0" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-cursor: hand;" text="🔍 Pesquisar" />

      <TableView fx:id="tabelaProdutos" layoutX="20.0" layoutY="105.0" onKeyPressed="#verificarEnter" prefHeight="280.0" prefWidth="560.0" style="-fx-border-color: #cccccc;">
        <columns>
          <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />
          <TableColumn fx:id="colDescricao" prefWidth="300.0" text="Descrição do Produto" />
          <TableColumn fx:id="colPreco" prefWidth="100.0" text="Preço (R$)" />
          <TableColumn fx:id="colEstoque" prefWidth="98.0" text="Estoque" />
        </columns>
      </TableView>

      <Button layoutX="430.0" layoutY="400.0" mnemonicParsing="false" onAction="#confirmarSelecao" prefHeight="35.0" prefWidth="150.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold;" text="✅ Confirmar" />
      
      <Label layoutX="20.0" layoutY="409.0" text="Dica: Use o leitor de código de barras no campo de busca." textFill="#7f8c8d">
         <font>
            <Font name="System Italic" size="12.0" />
         </font>
      </Label>
   </children>
</AnchorPane>