<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.MainController">
   <left>
      <VBox prefHeight="600.0" prefWidth="179.0" spacing="10" style="-fx-background-color: #37474f; -fx-padding: 5;">
         <children>
            <ImageView fitHeight="109.0" fitWidth="179.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../../../../Downloads/Logo%20HyperTech.png" />
               </image>
            </ImageView>
            
            <Button fx:id="btnPdv" mnemonicParsing="false" onAction="#irPedido" prefWidth="180.0" text="Frente de Caixa (PDV)" />
            
            <Button fx:id="btnReceber" mnemonicParsing="false" onAction="#irReceber" prefWidth="180.0" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold;" text="Receber Pagamentos" />
            
            <Button fx:id="btnFaturar" mnemonicParsing="false" onAction="#irFaturar" prefWidth="180.0" text="Faturar Vendas" />
            <Button fx:id="btnEstoque" mnemonicParsing="false" onAction="#irEstoque" prefWidth="180.0" text="Estoque" />
            <Button fx:id="btnClientes" mnemonicParsing="false" onAction="#irClientes" prefWidth="180.0" text="Clientes" />
            <Button fx:id="btnRelatorios" mnemonicParsing="false" onAction="#irRelatorios" prefWidth="180.0" text="Relatórios" />
            <Button fx:id="btnCancelarVenda" mnemonicParsing="false" onAction="#irCancelarVenda" prefWidth="180.0" text="Cancelar Venda" />
            
            <TitledPane fx:id="paneCaixa" animated="true" expanded="false" prefWidth="180.0" text="Financeiro / Caixa">
              <content>
                <VBox spacing="8.0" style="-fx-background-color: #2c3e50;">
                     <children>
                        <Button mnemonicParsing="false" onAction="#abrirEntradaCaixa" prefWidth="160.0" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="Cobertura (+)" />
                        <Button mnemonicParsing="false" onAction="#abrirSaidaCaixa" prefWidth="160.0" style="-fx-background-color: #c0392b; -fx-text-fill: white;" text="Retirada (-)" />
                     </children>
                </VBox>
              </content>
            </TitledPane>

            <TitledPane fx:id="paneCadastros" animated="true" expanded="false" prefWidth="180.0" text="Cadastros">
              <content>
                <VBox spacing="8.0" style="-fx-background-color: #34495e;">
                     <children>
                        <Button fx:id="btnCadProduto" mnemonicParsing="false" onAction="#irCadastroProduto" prefWidth="160.0" text="Novo Produto" />
                        <Button fx:id="btnCadCliente" mnemonicParsing="false" onAction="#irCadastroCliente" prefWidth="160.0" text="Novo Cliente" />
                        <Button fx:id="btnCadUsuarios" mnemonicParsing="false" onAction="#irCadastroUsuario" prefWidth="160.0" text="Config. Usuários" />
                     </children>
                </VBox>
              </content>
            </TitledPane>

            <Button mnemonicParsing="false" onAction="#sair" prefWidth="180.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Sair / Logoff" />
         </children>
      </VBox>
   </left>
   <center>
      <AnchorPane fx:id="painelCentral" style="-fx-background-color: #f4f4f4;" />
   </center>
</BorderPane>